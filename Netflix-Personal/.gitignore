dist
dist-ssr
build

# --- Variables de Entorno (SEGURIDAD CRÍTICA) ---
# Ignora cualquier archivo de configuración local que pueda tener tu API KEY
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Excepción: Si creas un archivo de ejemplo (sin claves reales), ese sí se sube
!.env.example

